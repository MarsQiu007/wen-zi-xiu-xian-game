[gd_resource type="Resource" load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/resources/world_event_template_data.gd" id="1"]

[resource]
script = ExtResource("1")
id = &"mvp_night_watch_patrol"
display_name = "夜巡戒备"
summary = "城镇或宗门组织夜巡，压制谣言与潜在袭扰，形成阶段性余波。"
tags = PackedStringArray("patrol", "aftermath", "shared")
human_visible = true
deity_visible = true
event_type = &"aftermath"
region_scope_tags = PackedStringArray("city", "village", "sect_hub")
required_actor_tags = PackedStringArray("guardian", "scribe")
required_faction_tags = PackedStringArray("settlement", "cultivation_sect")
trigger_tags = PackedStringArray("night_watch", "order_rebuild")
result_tags = PackedStringArray("stability", "fatigue")
severity = 1
key_participant_roles = PackedStringArray("patrol", "scribe", "resident")
pause_behavior = &"auto"
summary_template = "{faction} 在 {region} 组织夜巡，短期稳住局势并留下后续余波。"
